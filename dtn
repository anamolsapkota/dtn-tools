    list_neighbors()


DTN_SERVICES = ["dtnex", "dtn-chat", "dtn-discovery", "dtn-metadata-updater", "ionwd", "bpecho"]

SERVICE_ALIASES = {
    "chat": "dtn-chat",
    "discovery": "dtn-discovery",
    "metadata": "dtn-metadata-updater",
    "meta": "dtn-metadata-updater",
    "updater": "dtn-metadata-updater",
    "watchdog": "ionwd",
    "echo": "bpecho",
}


def _resolve_service(name):
    """Resolve a service alias to the systemd unit name."""
    if not name:
        return None
    name = name.lower().strip()
    if name in ("ion", "all"):
        return name
    if name in SERVICE_ALIASES:
        return SERVICE_ALIASES[name]
    if name in DTN_SERVICES:
        return name
    # Try with dtn- prefix
    if f"dtn-{name}" in DTN_SERVICES:
        return f"dtn-{name}"
    return name  # pass through as-is


def _stop_ion():
    """Stop ION cleanly."""
    import time
    print("Stopping ION...")
    run("ionstop 2>/dev/null", timeout=60)
    time.sleep(2)
    run("killm 2>/dev/null", timeout=30)
    time.sleep(1)


def _start_ion():
    """Start ION from host.rc."""
    detect_ipn()
    print(f"Starting ION from {HOST_RC}...")
    out, err, rc = run(f"ionstart -I {HOST_RC} 2>&1", timeout=120)
    if rc != 0:
        print(f"ION start failed: {err}")
        return False
    print("ION started.")
    return True


def _stop_services(services=None):
    """Stop systemd services."""
    svcs = services or ["dtn-discovery", "dtn-chat", "dtnex", "dtn-metadata-updater"]
    for svc in svcs:
        run(f"sudo systemctl stop {svc}.service 2>/dev/null", timeout=30)
        print(f"  stopped {svc}")


def _start_services(services=None):
    """Start systemd services."""
    svcs = services or ["ionwd", "dtnex", "bpecho", "dtn-chat", "dtn-discovery", "dtn-metadata-updater"]
    for svc in svcs:
        run(f"sudo systemctl start {svc}.service 2>/dev/null", timeout=30)
        # Check if it actually started
        _, _, rc = run(f"systemctl is-active {svc}.service 2>/dev/null")
        status = "started" if rc == 0 else "not available"
        print(f"  {svc}: {status}")


def cmd_start(args):
    """Start ION and/or DTN services."""
    target = _resolve_service(getattr(args, "service", None))

    if target is None or target == "all":
        # Start everything
        _start_ion()
        print("Starting services...")
        _start_services()
        print("DTN node started.")
    elif target == "ion":
        _start_ion()
    else:
        print(f"Starting {target}...")
        _start_services([target])


def cmd_stop(args):
    """Stop ION and/or DTN services."""
    target = _resolve_service(getattr(args, "service", None))

    if target is None or target == "all":
        # Stop everything
        print("Stopping services...")
        _stop_services()
        _stop_ion()
        print("DTN node stopped.")
    elif target == "ion":
        _stop_ion()
    else:
        print(f"Stopping {target}...")
        _stop_services([target])


def cmd_restart(args):
    """Restart ION and/or DTN services."""
    import time
    target = _resolve_service(getattr(args, "service", None))

    if target is None or target == "all":
        # Full restart
        print("Stopping services...")
        _stop_services()
        _stop_ion()
        _start_ion()
        print("Starting services...")
        _start_services()
        print("DTN node restarted.")
    elif target == "ion":
        _stop_ion()
        _start_ion()
    else:
        print(f"Restarting {target}...")
        _stop_services([target])
        time.sleep(1)
        _start_services([target])


def cmd_enable(args):
    """Enable DTN services to start on boot."""
    target = _resolve_service(getattr(args, "service", None))

    if target is None or target == "all":
        print("Enabling all DTN services on boot...")
        for svc in DTN_SERVICES:
            run(f"sudo systemctl enable {svc}.service 2>/dev/null", timeout=30)
            _, _, rc = run(f"systemctl is-enabled {svc}.service 2>/dev/null")
            status = "enabled" if rc == 0 else "not available"
            print(f"  {svc}: {status}")
    elif target == "ion":
        print("Enabling ionwd (ION watchdog) on boot...")
        run("sudo systemctl enable ionwd.service 2>/dev/null", timeout=30)
        _, _, rc = run("systemctl is-enabled ionwd.service 2>/dev/null")
        print(f"  ionwd: {'enabled' if rc == 0 else 'not available'}")
    else:
        run(f"sudo systemctl enable {target}.service 2>/dev/null", timeout=30)
        _, _, rc = run(f"systemctl is-enabled {target}.service 2>/dev/null")
        status = "enabled" if rc == 0 else "not available"
        print(f"{target}: {status}")


def cmd_disable(args):
    """Disable DTN services from starting on boot."""
    target = _resolve_service(getattr(args, "service", None))

    if target is None or target == "all":
        print("Disabling all DTN services on boot...")
        for svc in DTN_SERVICES:
            run(f"sudo systemctl disable {svc}.service 2>/dev/null", timeout=30)
            print(f"  {svc}: disabled")
    elif target == "ion":
        run("sudo systemctl disable ionwd.service 2>/dev/null", timeout=30)
        print("ionwd: disabled")
    else:
        run(f"sudo systemctl disable {target}.service 2>/dev/null", timeout=30)
        print(f"{target}: disabled")


def cmd_logs(args):
    """Tail service logs."""
    svc = args.service or "dtnex"
    svc_map = {
        "dtnex": "dtnex",
        "discovery": "dtn-discovery",
        "chat": "dtn-chat",
        "ionwd": "ionwd",
        "metadata": "dtn-metadata-updater",
        "ion": None,
    }
    if svc == "ion":
        os.execvp("tail", ["tail", "-f", os.path.join(DTN_DIR, "ion.log")])
    elif svc in svc_map:
        os.execvp("journalctl", ["journalctl", "-u", f"{svc_map[svc]}.service", "-f"])
    else:
        print(f"Unknown service: {svc}")
        print(f"Available: {', '.join(svc_map.keys())}")


