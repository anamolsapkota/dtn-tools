SCRIPT_DIR = os.path.dirname(os.path.realpath(__file__))


def _import_module(name, filename):
    """Import a module from dtn_tools/ relative to the real script location."""
    try:
        mod = __import__(f"dtn_tools.{name}", fromlist=[name])
        return mod
    except ImportError:
        pass
    mod_path = os.path.join(SCRIPT_DIR, "dtn_tools", filename)
    if os.path.exists(mod_path):
        import importlib.util
        spec = importlib.util.spec_from_file_location(f"dtn_tools.{name}", mod_path)
        mod = importlib.util.module_from_spec(spec)
        spec.loader.exec_module(mod)
        return mod
    print(f"Error: dtn_tools/{filename} not found")
    sys.exit(1)


def cmd_init(args):
    """Run the DTN node setup wizard."""
    mod = _import_module("init", "init.py")
    mod.run_init(args)


def cmd_status(_args):
    """Show node and service status."""
    detect_ipn()
    print(f"DTN Node: ipn:{MY_IPN}")
    print(f"DTN Dir:  {DTN_DIR}")
    print(f"Host RC:  {HOST_RC}")
    print()

    # ION version
    out, _, _ = run("bpversion 2>/dev/null || echo 'ION not running'")
    print(f"ION Version: {out}")

    # ION status
    out, _, rc = run_admin("ionadmin", "l\nq")
    if rc == 0 and out:
        print(f"ION Status: Running")
    else:
        print(f"ION Status: NOT RUNNING")

    print()

    # Service status
    services = ["ionwd", "dtnex", "bpecho", "dtn-chat", "dtn-discovery", "dtn-metadata-updater"]
    print(f"{'Service':<25} {'Status':<12} {'PID'}")
    print("-" * 55)
    for svc in services:
        out, _, rc = run(f"systemctl is-active {svc}.service 2>/dev/null")
        status = out if rc == 0 else "inactive"
        pid = ""
        if status == "active":
            p_out, _, _ = run(f"systemctl show {svc}.service --property=MainPID --value 2>/dev/null")
            pid = p_out
        print(f"{svc:<25} {status:<12} {pid}")

    print()

    # Bundle stats
    out, _, _ = run_admin("bpadmin", "w\nq")
    if out:
        print("Bundle Protocol Stats:")
        for line in out.splitlines():
            line = line.strip()
            if line and not line.startswith(":"):
                print(f"  {line}")


def cmd_neighbors(args):
    """List, add, or remove neighbors."""
    detect_ipn()

    if args.action == "add":
        if not args.ipn or not args.ip:
            print("Usage: dtn neighbors add <IPN> <IP>")
            sys.exit(1)
        add_neighbor(args.ipn, args.ip)
    elif args.action == "remove":
        if not args.ipn:
            print("Usage: dtn neighbors remove <IPN>")
            sys.exit(1)
        remove_neighbor(args.ipn)
    elif args.action == "ping":
        ping_neighbors(args.ipn)
    else:
        list_neighbors()


def list_neighbors():
    """List configured neighbors from ION plans."""
    out, _, _ = run_admin("ipnadmin", "l plan\nq")
    if not out:
        print("No plans configured (is ION running?)")
        return

    print(f"{'IPN':<14} {'Outduct':<30} {'Rate'}")
    print("-" * 60)
    for line in out.splitlines():
        line = line.strip().lstrip(":").strip()
        if not line or line.startswith("Stopping"):
            continue
        # Format: "268485000 xmit 100.96.108.37:4556 xmit rate: 0"
        m = re.match(r"(\d+)\s+xmit\s+(\S+)\s+xmit rate:\s*(\d+)", line)
        if m:
            ipn, outduct, rate = m.groups()
            print(f"ipn:{ipn:<10} {outduct:<30} {rate}")


def add_neighbor(ipn, ip):
    """Add a new neighbor to running ION + host.rc (fully persistent)."""
    detect_ipn()
    print(f"Adding neighbor ipn:{ipn} at {ip}...")
    _add_neighbor_direct(ipn, ip)


def _add_neighbor_direct(ipn, ip):
    """Add neighbor directly via ION admin commands."""
    port = "4556"
    rate = "100000"
    duration = "360000000"

    # Add contacts and ranges
    ion_cmds = f"""a contact +1 +{duration} {MY_IPN} {ipn} {rate}
a contact +1 +{duration} {ipn} {MY_IPN} {rate}
a range +1 +{duration} {MY_IPN} {ipn} 1
a range +1 +{duration} {ipn} {MY_IPN} 1
q
"""
    out, err, rc = run_admin("ionadmin", ion_cmds)
    if rc != 0 and rc != 124:
        print(f"ionadmin error: {err}")
        return

    # Brief pause to let ION process route updates before modifying plans
    import time
    time.sleep(2)

    # Add outduct
    bp_cmds = f"a outduct udp {ip}:{port} udpclo\nq\n"
    run_admin("bpadmin", bp_cmds)

    # Add plan
    ipn_cmds = f"a plan {ipn} udp/{ip}:{port}\nq\n"
    run_admin("ipnadmin", ipn_cmds)

    # Update neighbours.conf
    if os.path.exists(NEIGHBOURS_FILE):
        with open(NEIGHBOURS_FILE, "a") as f:
            f.write(f"node-{ipn} {ipn} {ip}\n")

    # Persist to host*.rc
    _persist_add_to_hostrc(ipn, ip, port, rate, duration)

    print(f"Added neighbor ipn:{ipn} at {ip}:{port}")
    print("Contacts, outduct, and plan configured (running ION + host.rc).")


def _find_hostrc():
    """Find the host*.rc file."""
    detect_ipn()
    candidates = list(Path(DTN_DIR).glob(f"host{MY_IPN}.rc"))
    if candidates:
        return str(candidates[0])
    # Try any host*.rc
    candidates = list(Path(DTN_DIR).glob("host*.rc"))
    if candidates:
        return str(candidates[0])
    return None


def _persist_add_to_hostrc(ipn, ip, port, rate, duration):
    """Add a neighbor to the host*.rc file for persistence across restarts."""
    hostrc = _find_hostrc()
    if not hostrc:
        return

    content = Path(hostrc).read_text()

    # Check if already in file
    if f"{MY_IPN} {ipn} {rate}" in content and f"a plan {ipn}" in content:
        return

    # Add contacts/ranges before "## end ionadmin"
    ion_block = f"""
# Neighbor ipn:{ipn}
a contact +1 +{duration} {MY_IPN} {ipn} {rate}
a contact +1 +{duration} {ipn} {MY_IPN} {rate}
a range +1 +{duration} {MY_IPN} {ipn} 1
a range +1 +{duration} {ipn} {MY_IPN} 1"""
    content = content.replace("## end ionadmin", ion_block + "\n## end ionadmin")

    # Add outduct before "## end bpadmin"
    bp_block = f"\na outduct udp {ip}:{port} udpclo"
    content = content.replace("## end bpadmin", bp_block + "\n## end bpadmin")

    # Add plan before "## end ipnadmin"
    ipn_block = f"\na plan {ipn} udp/{ip}:{port}"
    content = content.replace("## end ipnadmin", ipn_block + "\n## end ipnadmin")

    Path(hostrc).write_text(content)
    print(f"  Updated {hostrc}")


def _persist_remove_from_hostrc(ipn):
    """Remove a neighbor from the host*.rc file."""
    hostrc = _find_hostrc()
    if not hostrc:
        return

    lines = Path(hostrc).read_text().splitlines()
    new_lines = []
    for line in lines:
        # Skip lines referencing this IPN (contacts, ranges, outducts, plans)
        stripped = line.strip()
        if stripped.startswith("#") and (f"ipn:{ipn}" in stripped or f"neighbour {ipn}" in stripped or f"Neighbor {ipn}" in stripped or f"neighbor {ipn}" in stripped):
            continue
        if re.search(rf"\b{MY_IPN}\s+{ipn}\b", stripped):
            continue
        if re.search(rf"\b{ipn}\s+{MY_IPN}\b", stripped):
            continue
        if re.search(rf"a plan {ipn}\b", stripped):
            continue
        # Match outduct by looking for the IP from plan
        # (outducts don't have IPN, so we handle them separately)
        new_lines.append(line)

    Path(hostrc).write_text("\n".join(new_lines) + "\n")
    print(f"  Updated {hostrc}")


def remove_neighbor(ipn):
    """Remove a neighbor from the running ION instance and host.rc."""
    detect_ipn()
    print(f"Removing neighbor ipn:{ipn}...")

    # Get the current plan to find the IP
    out, _, _ = run_admin("ipnadmin", "l plan\nq")
    ip = None
    for line in out.splitlines():
        line = line.strip().lstrip(":").strip()
        m = re.match(rf"{ipn}\s+xmit\s+(\S+)", line)
        if m:
            ip = m.group(1)
            break

    # Delete contacts
    ion_cmds = f"""d contact +1 {MY_IPN} {ipn}
d contact +1 {ipn} {MY_IPN}
d range +1 {MY_IPN} {ipn}
d range +1 {ipn} {MY_IPN}
q
"""
    run_admin("ionadmin", ion_cmds)

    # Delete plan
    ipn_cmds = f"d plan {ipn}\nq\n"
    run_admin("ipnadmin", ipn_cmds)

    # Delete outduct if we found the IP
    if ip:
        bp_cmds = f"d outduct udp {ip}\nq\n"
        run_admin("bpadmin", bp_cmds)

    # Remove from neighbours.conf
    if os.path.exists(NEIGHBOURS_FILE):
        lines = []
        with open(NEIGHBOURS_FILE) as f:
            for line in f:
                if ipn not in line:
                    lines.append(line)
        with open(NEIGHBOURS_FILE, "w") as f:
            f.writelines(lines)

    # Persist removal to host*.rc
    _persist_remove_from_hostrc(ipn)

    print(f"Removed neighbor ipn:{ipn} (running ION + host.rc updated)")


def ping_neighbors(target_ipn=None):
    """Ping one or all neighbors.

    target_ipn can be:
      - None: ping all neighbors on .12161
      - "268485091": ping one neighbor on .12161
      - "268485091.2": ping one neighbor on specific service number
    """
    detect_ipn()
    src = f"ipn:{MY_IPN}.3"

    # Parse optional service number from target
    svc = "12161"  # default: openipn.org bpecho endpoint
    if target_ipn and "." in target_ipn:
        target_ipn, svc = target_ipn.rsplit(".", 1)

    # Get plans
    out, _, _ = run_admin("ipnadmin", "l plan\nq")
    targets = []
    for line in out.splitlines():
        line = line.strip().lstrip(":").strip()
        m = re.match(r"(\d+)\s+xmit", line)
        if m:
            n = m.group(1)
            if n != MY_IPN:
                if target_ipn and n != target_ipn:
                    continue
                targets.append(n)

    # Allow pinging any IPN (not just neighbors with plans)
    if target_ipn and target_ipn not in targets:
        targets = [target_ipn]

    if not targets:
        print("No neighbors to ping.")
        return

    for ipn in targets:
        dest = f"ipn:{ipn}.{svc}"
        print(f"Pinging ipn:{ipn} ({src} -> {dest})...", end=" ", flush=True)
        out, err, rc = run(f"timeout 15 bping -c 1 -i 1 {src} {dest} 2>&1")
        if "bundle loss, time" in out:
            m = re.search(r"time=(\S+)\s+s", out)
            loss_m = re.search(r"(\d+\.?\d*)%\s+bundle loss", out)
            rtt = f"{float(m.group(1))*1000:.0f}ms" if m else "?"
            loss = float(loss_m.group(1)) if loss_m else 100
            if loss == 0:
                print(f"UP (rtt={rtt})")
            else:
                print(f"DOWN (loss={loss:.0f}%)")
        else:
            print("DOWN (timeout)")


def cmd_discover(args):
    """Query discovered nodes."""
    if not os.path.exists(DISCOVERY_SCRIPT):
        print(f"Discovery tool not found: {DISCOVERY_SCRIPT}")
        print("Install dtn-discovery first.")
        sys.exit(1)

    if args.subaction == "summary":
        os.execvp("python3", ["python3", DISCOVERY_SCRIPT, "--summary"])
    elif args.subaction == "search":
        if not args.query:
            print("Usage: dtn discover search <query>")
            sys.exit(1)
        os.execvp("python3", ["python3", DISCOVERY_SCRIPT, "--search", args.query])
    else:
        os.execvp("python3", ["python3", DISCOVERY_SCRIPT])


def cmd_send(args):
    """Send a DTN bundle message."""
    detect_ipn()
    if not args.dest:
        print("Usage: dtn send <IPN|all> <message>")
        sys.exit(1)

    message = " ".join(args.message) if args.message else f"Hello from ipn:{MY_IPN}"

    if args.dest == "all":
        # Send to all neighbors
        out, _, _ = run_admin("ipnadmin", "l plan\nq")
        targets = []
        for line in out.splitlines():
            line = line.strip().lstrip(":").strip()
            m = re.match(r"(\d+)\s+xmit", line)
            if m and m.group(1) != MY_IPN:
                targets.append(m.group(1))
        for ipn in targets:
            dest = f"ipn:{ipn}.1"
            print(f"Sending to {dest}...", end=" ")
            _, _, rc = run(f'bpsource "{dest}" "{message}" 2>&1')
            print("OK" if rc == 0 else "FAILED")
    else:
        dest_ipn = args.dest.replace("ipn:", "")
        dest = f"ipn:{dest_ipn}.1"
        print(f"Sending to {dest}: {message}")
        out, err, rc = run(f'bpsource "{dest}" "{message}" 2>&1')
        if rc == 0:
            print("Sent.")
        else:
            print(f"Failed: {err}")


def cmd_chat(args):
    """Interactive terminal chat over DTN bundles."""
    import threading
    import time
    import tempfile
    import signal

    detect_ipn()
    CHAT_SVC = "5"  # service number for terminal chat (standard endpoint on all nodes)
    recv_dir = tempfile.mkdtemp(prefix="dtn-chat-")
    recv_eid = f"ipn:{MY_IPN}.{CHAT_SVC}"
    running = True

    # Ensure chat endpoint exists in ION
    run_admin("bpadmin", f"a endpoint {recv_eid} q\nq\n")

    # Load discovery DB for node names
    node_names = {}
    if os.path.exists(DISCOVERY_DB):
        try:
            import json
            with open(DISCOVERY_DB) as f:
                for ipn, info in json.load(f).get("nodes", {}).items():
                    if info.get("name"):
                        node_names[ipn] = info["name"]
        except Exception:
            pass

    def node_label(ipn):
        name = node_names.get(ipn, "")
        return f"{name} (ipn:{ipn})" if name else f"ipn:{ipn}"

    def send_bundle(dest_ipn, msg):
        """Send a chat message as a DTN bundle."""
        import json as _json
        dest = f"ipn:{dest_ipn}.{CHAT_SVC}"
        payload = _json.dumps({
            "from": MY_IPN,
            "name": os.environ.get("USER", "unknown"),
            "msg": msg,
            "ts": time.strftime("%H:%M:%S"),
        })
        _, _, rc = run(f"bpsource {dest} '{payload}' 2>/dev/null")
        return rc == 0

    def receiver_thread():
        """Background thread: run bprecvfile and poll for incoming messages."""
        import json as _json
        # Start bprecvfile — no count limit so it runs continuously
        proc = subprocess.Popen(
            ["bprecvfile", recv_eid],
            cwd=recv_dir,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
        )
        while running:
            time.sleep(0.5)
            # Restart bprecvfile if it died
            if proc.poll() is not None and running:
                proc = subprocess.Popen(
                    ["bprecvfile", recv_eid],
                    cwd=recv_dir,
                    stdout=subprocess.DEVNULL,
                    stderr=subprocess.DEVNULL,
                )
            # Poll for new files
            try:
                for fname in sorted(os.listdir(recv_dir)):
                    fpath = os.path.join(recv_dir, fname)
                    if not os.path.isfile(fpath):
                        continue
                    try:
                        with open(fpath) as f:
                            content = f.read().strip()
                        os.unlink(fpath)
                        if not content:
                            continue

                        # Try to parse as JSON chat message
                        try:
                            data = _json.loads(content)
                            sender = data.get("from", "?")
                            name = data.get("name", "")
                            msg = data.get("msg", content)
                            ts = data.get("ts", "")
                            label = name or node_label(sender)
                            print(f"\r  [{ts}] {label}: {msg}")
                        except _json.JSONDecodeError:
                            # Plain text bundle
                            print(f"\r  [bundle] {content}")
                        # Reprint prompt
                        if dest_ipn_target:
                            print(f"  you> ", end="", flush=True)
                    except Exception:
                        pass
            except Exception:
                pass
        proc.terminate()

    # Parse mode
    dest_ipn_target = None
    if hasattr(args, "dest") and args.dest:
        dest_ipn_target = args.dest.replace("ipn:", "")

    if dest_ipn_target and hasattr(args, "message") and args.message:
        # One-shot mode: dtn chat <IPN> "message"
        msg = " ".join(args.message)
        print(f"  Sending to {node_label(dest_ipn_target)}: {msg}")
        if send_bundle(dest_ipn_target, msg):
            print("  Sent.")
        else:
            print("  Failed.")
        return

    def list_nodes():
        """Show all reachable nodes from the contact graph."""
        # Get all unique IPNs from contact graph
        out, _, _ = run_admin("ionadmin", "l contact\nq")
        all_ipns = set()
        for l in out.splitlines():
            m = re.search(r"node\s+(\d+)\s+to\s+node\s+(\d+)", l)
            if m:
                all_ipns.add(m.group(1))
                all_ipns.add(m.group(2))
        all_ipns.discard(MY_IPN)

        # Get plans to mark direct neighbors
        plan_out, _, _ = run_admin("ipnadmin", "l plan\nq")
        plans = set()
        for l in plan_out.splitlines():
            l = l.strip().lstrip(":").strip()
            m = re.match(r"(\d+)\s+xmit", l)
            if m and m.group(1) != MY_IPN:
                plans.add(m.group(1))

        nodes = sorted(all_ipns, key=lambda x: int(x))

        if nodes:
            print()
            print(f"  Available nodes ({len(nodes)}):")
            for i, ipn in enumerate(nodes, 1):
                tag = " *" if ipn in plans else ""
                print(f"    {i:>3}. {node_label(ipn)}{tag}")
            print()
            print("  * = direct neighbor.  All others routed via contact graph.")
            print("  Type a number to select, or enter an IPN directly.")
        else:
            print("  No nodes found. Is ION running?")
        return nodes

    # Interactive mode
    print("=" * 60)
    print("  DTN Terminal Chat")
    print(f"  Your node: {node_label(MY_IPN)}")
    print(f"  Listening on: {recv_eid}")
    print("=" * 60)

    # Show nodes and let user pick if no dest set
    neighbors = list_nodes()

    if not dest_ipn_target:
        while True:
            try:
                choice = input("\n  Select node to chat with: ").strip()
            except (EOFError, KeyboardInterrupt):
                print("\n  Cancelled.")
                return
            if not choice:
                continue
            choice = choice.replace("ipn:", "")
            # Try as number (index into list)
            if choice.isdigit() and 1 <= int(choice) <= len(neighbors):
                dest_ipn_target = neighbors[int(choice) - 1]
                break
            # Try as IPN directly
            if choice.isdigit() and len(choice) >= 6:
                dest_ipn_target = choice
                break
            print("  Invalid selection. Enter a number or IPN.")

    print()
    print(f"  Chatting with: {node_label(dest_ipn_target)}")
    print(f"  Type messages and press Enter. Ctrl+C or 'quit' to exit.")
    print("-" * 60)

    # Start receiver
    recv_thread = threading.Thread(target=receiver_thread, daemon=True)
    recv_thread.start()

    try:
        while True:
            try:
                line = input(f"  you> ").strip()
            except EOFError:
                break

            if not line:
                continue

            # Commands — with or without / prefix
            cmd = line.lstrip("/").lower()
            if cmd in ("quit", "exit", "q"):
                break
            elif cmd.startswith("to "):
                val = cmd[3:].strip().replace("ipn:", "")
                # Support number selection
                if val.isdigit() and 1 <= int(val) <= len(neighbors):
                    dest_ipn_target = neighbors[int(val) - 1]
                else:
                    dest_ipn_target = val
                print(f"  Now chatting with: {node_label(dest_ipn_target)}")
                continue
            elif cmd == "nodes":
                neighbors = list_nodes()
                continue
            elif cmd == "help":
                print("  Commands: to <IPN|#>  nodes  quit  help")
                continue
            elif line.startswith("/"):
                print("  Unknown command. Try: to, nodes, quit, help")
                continue

            if send_bundle(dest_ipn_target, line):
                pass  # sent
            else:
                print("  [send failed]")

    except KeyboardInterrupt:
        pass
    finally:
        running = False
        print("\n  Chat ended.")
        import shutil as _shutil
        _shutil.rmtree(recv_dir, ignore_errors=True)


